<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.sentra.scdlp.helper</string>
    <!-- Reference template. The installed plist is generated by scdlp-host at
         activation time, pointing at the helper bundled inside scdlp.app. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/scdlp.app/Contents/Library/scdlp-helper.app/Contents/MacOS/scdlp-helper</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
</dict>
</plist>
